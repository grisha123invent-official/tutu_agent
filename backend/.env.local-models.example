# ============================================================
#  Пример backend/.env для работы на ЛОКАЛЬНЫХ моделях
#  (скопируйте нужное в backend/.env). Живой сайт это не трогает —
#  прод остаётся на OpenAI. Подробности: docs/LOCAL_MODELS.md
# ============================================================

# --- MCP Туту (не меняется) ---
TUTU_MCP_URL=https://mcp.tutu.ru/mcp
PORT=8787

# --- LLM: локальная модель через OpenAI-совместимый API ---
# Ollama / vLLM / LM Studio / LocalAI. Модель ОБЯЗАНА уметь tool calling.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:14b-instruct
LLM_API_KEY=local

# --- Голос: локальный конвейер STT → LLM → TTS ---
VOICE_PROVIDER=local

# STT (speaches / faster-whisper-server), OpenAI-совместимый
STT_BASE_URL=http://localhost:8001/v1
STT_MODEL=Systran/faster-whisper-small
STT_API_KEY=local

# TTS (openedai-speech / Kokoro-FastAPI), OpenAI-совместимый
TTS_BASE_URL=http://localhost:8002/v1
TTS_MODEL=tts-1
TTS_VOICE=alloy
TTS_SAMPLE_RATE=24000
TTS_API_KEY=local

# Тонкая настройка серверного VAD (определение конца реплики)
LOCAL_VAD_THRESHOLD=0.012
LOCAL_END_SILENCE_MS=700
LOCAL_MIN_SPEECH_MS=300

# --- Веб-поиск: свой SearXNG вместо OpenAI ---
WEB_SEARCH_PROVIDER=searxng
SEARXNG_URL=http://localhost:8080

# --- OpenAI не нужен в полностью локальном режиме ---
# OPENAI_API_KEY=
